<script>
document.addEventListener('DOMContentLoaded', function() {
  // Mobile nav
  var hb = document.getElementById('hb');
  var mm = document.getElementById('mm');
  if (hb && mm) {
    hb.addEventListener('click', function() {
      var nowOpen = !mm.classList.contains('open');
      mm.classList.toggle('open', nowOpen);
      hb.classList.toggle('open', nowOpen);
    });
    mm.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        mm.classList.remove('open');
        hb.classList.remove('open');
      });
    });
  }

  // Scroll active service pill into view
  var activePill = document.querySelector('.svc-pill.active');
  if (activePill) {
    setTimeout(function() {
      activePill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }, 300);
  }

  // FAQ accordion
  var fqItems = document.querySelectorAll('.fq-item');
  fqItems.forEach(function(item) {
    var btn = item.querySelector('.fqb');
    var ans = item.querySelector('.fq-ans');
    var ic = item.querySelector('.fq-ic');
    if (!btn || !ans) return;
    btn.addEventListener('click', function() {
      var open = ans.style.display !== 'none';
      fqItems.forEach(function(i) {
        var a = i.querySelector('.fq-ans');
        var b = i.querySelector('.fqb');
        var ic2 = i.querySelector('.fq-ic');
        if (a) a.style.display = 'none';
        if (b) b.setAttribute('aria-expanded', 'false');
        if (ic2) { ic2.style.background = '#e2e2e2'; ic2.style.transform = 'rotate(0deg)'; }
      });
      if (!open) {
        ans.style.display = 'block';
        btn.setAttribute('aria-expanded', 'true');
        if (ic) { ic.style.background = '#064187'; ic.style.transform = 'rotate(45deg)'; }
      }
    });
  });
});
</script>
