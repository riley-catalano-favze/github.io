  --border-light: #e2e2e2;
  --text-muted: rgba(255,255,255,0.58);
  --font-display: 'Barlow Condensed', sans-serif;
  --font-body: 'DM Sans', sans-serif;
  --radius-card: 20px;
  --radius-sm: 10px;
  --section-pad: 96px 5%;
  --inner-max: 1160px;
}
html, body { overflow-x: clip; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: var(--dark); color: var(--white); line-height: 1.6; }
a { color: inherit; text-decoration: none; }
img { max-width: 100%; height: auto; display: block; }
button { font-family: var(--font-body); cursor: pointer; }

/* NAV */
nav {
  position: sticky; top: 0; z-index: 100;
  background: #fff; border-bottom: 1.5px solid #e8e8e8;
  padding: 0 5%; display: flex; align-items: center; justify-content: space-between;
  height: 68px;
}
.nl { display: flex; align-items: center; gap: 4px; list-style: none; }
.nl a { font-family: var(--font-body); font-weight: 500; font-size: 0.875rem; padding: 7px 12px; border-radius: 8px; color: #0a0a0a; transition: background .2s; }
.nl a:hover { background: #f0f0f0; }
.nl a.active { color: var(--navy); font-weight: 700; }
.nc { background: var(--navy) !important; color: #fff !important; padding: 9px 18px !important; border-radius: 9px !important; font-weight: 700 !important; transition: background .2s !important; }
.nc:hover { background: var(--teal) !important; }
.hb { display: none; flex-direction: column; gap: 5px; cursor: pointer; border: none; background: none; padding: 6px; }
.hb span { display: block; width: 24px; height: 2px; background: #0a0a0a; border-radius: 2px; transition: .25s; }
.hb.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hb.open span:nth-child(2) { opacity: 0; }
.hb.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
.mm { display: none; position: fixed; top: 68px; left: 0; right: 0; background: #fff; border-bottom: 1.5px solid #e8e8e8; padding: 18px 5% 22px; z-index: 99; flex-direction: column; gap: 2px; box-shadow: 0 16px 48px rgba(0,0,0,.12); }
.mm.open { display: flex; }
.mm a { font-weight: 500; font-size: 1rem; padding: 12px 14px; border-radius: 8px; display: block; color: #0a0a0a; transition: background .2s; }
.mm a:hover { background: #f0f0f0; }
.mc { background: var(--navy) !important; color: #fff !important; text-align: center; margin-top: 8px; font-weight: 700 !important; }
.nav-logo-img { height: 30px; width: auto; }

/* SERVICE NAV STRIP */
.svc-nav {
  background: var(--dark2);
  border-bottom: 1px solid rgba(255,255,255,.06);
  overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none;
}
.svc-nav::-webkit-scrollbar { display: none; }
.svc-nav-inner { display: flex; align-items: center; padding: 0 5%; white-space: nowrap; min-width: max-content; }
.svc-pill {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 11px 18px; font-size: 12px; font-weight: 700;
  letter-spacing: .06em; text-transform: uppercase;
  color: rgba(255,255,255,.45);
  border-right: 1px solid rgba(255,255,255,.06);
  transition: all .15s; cursor: pointer;
}
.svc-pill:hover { background: rgba(255,255,255,.04); color: rgba(255,255,255,.85); }
.svc-pill.active {
  background: linear-gradient(135deg, var(--navy), var(--teal));
  color: #fff;
}
.svc-pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: .6; }
.svc-pill.active .svc-pill-dot { opacity: 1; background: rgba(255,255,255,.9); }

/* HERO */
.hero {
  position: relative; overflow: visible;
  background: var(--dark); padding: 100px 5% 88px;
  min-height: 76vh; display: flex; align-items: center;
}
.hero-grid {
  position: absolute; inset: 0;
  background-image: linear-gradient(rgba(6,65,135,.065) 1px, transparent 1px), linear-gradient(90deg, rgba(6,65,135,.065) 1px, transparent 1px);
  background-size: 52px 52px; pointer-events: none;
}
.hero-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 70% at 80% 20%, rgba(10,137,163,.2) 0%, transparent 65%), radial-gradient(ellipse 40% 50% at 15% 85%, rgba(6,65,135,.28) 0%, transparent 60%);
  pointer-events: none;
}
.hero-inner { position: relative; max-width: var(--inner-max); margin: 0 auto; width: 100%; display: grid; grid-template-columns: 1fr 460px; gap: 56px; align-items: center; }
.hero-badge { display: inline-flex; align-items: center; gap: 9px; background: rgba(10,137,163,.14); border: 1px solid rgba(10,137,163,.38); border-radius: 100px; padding: 6px 18px; font-size: 0.72rem; font-weight: 700; letter-spacing: .11em; text-transform: uppercase; color: var(--teal); margin-bottom: 26px; }
.hdot { width: 8px; height: 8px; background: var(--teal); border-radius: 50%; animation: pulse 2.2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }
.hero h1 { font-family: var(--font-display); font-weight: 900; text-transform: uppercase; line-height: 1.0; letter-spacing: -0.01em; margin-bottom: 28px; }
.hero-h1-line { display: block; font-size: clamp(3rem, 5.5vw, 6rem); }
.hero-h1-line.teal { color: var(--teal); }
.hero-h1-line.boxed { display: inline-block; color: var(--navy); background: var(--white); padding: 2px 14px 4px; border-radius: 6px; line-height: 1.05; margin-top: 4px; }
.hero-sub { font-size: 1.08rem; color: rgba(255,255,255,.62); line-height: 1.75; max-width: 540px; margin-bottom: 40px; }
.hero-ctas { display: flex; flex-wrap: wrap; gap: 14px; }
.btn-primary { background: var(--navy); color: #fff; font-weight: 700; padding: 14px 28px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 9px; font-size: 0.95rem; border: none; cursor: pointer; transition: background .2s; font-family: var(--font-body); }
.btn-primary:hover { background: var(--teal); }
.btn-ghost { background: transparent; color: #fff; font-weight: 700; padding: 13px 26px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 9px; font-size: 0.95rem; border: 1.5px solid rgba(255,255,255,.25); transition: .2s; font-family: var(--font-body); }
.btn-ghost:hover { background: rgba(255,255,255,.07); }
.hero-stats { display: flex; flex-wrap: wrap; gap: 36px; margin-top: 48px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.09); }
.hstat-num { font-family: var(--font-display); font-size: 2.6rem; font-weight: 900; color: var(--teal); line-height: 1; }
.hstat-label { font-size: 0.81rem; color: rgba(255,255,255,.48); margin-top: 4px; line-height: 1.45; }

/* HERO VISUAL — EMAIL PREVIEW CARDS */
.hero-visual { display: flex; align-items: center; justify-content: center; width: 100%; }
.email-stack { width: 100%; max-width: 460px; display: flex; flex-direction: column; gap: 10px; }
.email-card {
  background: rgba(255,255,255,.04); border: 1.5px solid rgba(255,255,255,.07);
  border-radius: 14px; padding: 16px 18px;
  display: flex; align-items: center; gap: 14px;
  transition: background .2s;
}
.email-card:hover { background: rgba(255,255,255,.07); }
.email-card.featured { border-color: rgba(10,137,163,.45); background: rgba(10,137,163,.07); }
.email-icon { width: 44px; height: 44px; border-radius: 11px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 20px; }
.email-icon.inbox { background: rgba(10,137,163,.2); border: 1.5px solid rgba(10,137,163,.4); }
.email-icon.seg { background: rgba(6,65,135,.2); border: 1.5px solid rgba(6,65,135,.45); }
.email-icon.auto { background: rgba(52,168,83,.18); border: 1.5px solid rgba(52,168,83,.35); }
.email-icon.ai { background: rgba(255,180,0,.15); border: 1.5px solid rgba(255,180,0,.35); }
.email-icon.analytics { background: rgba(234,67,53,.15); border: 1.5px solid rgba(234,67,53,.3); }
.email-card-name { font-family: var(--font-display); font-size: 1.1rem; font-weight: 900; text-transform: uppercase; color: #fff; letter-spacing: .04em; line-height: 1.1; }
.email-card-desc { font-size: 0.78rem; color: rgba(255,255,255,.5); margin-top: 2px; line-height: 1.4; }
.email-badge { margin-left: auto; flex-shrink: 0; font-size: 0.65rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; white-space: nowrap; }
.badge-core { background: rgba(10,137,163,.2); border: 1px solid rgba(10,137,163,.45); color: var(--teal); }
.badge-ai { background: rgba(255,180,0,.15); border: 1px solid rgba(255,180,0,.35); color: #ffb400; }

/* MARQUEE */
.mq { background: #ebebeb; overflow: hidden; border-bottom: 1.5px solid #d4d4d4; }
.mt { display: flex; align-items: center; white-space: nowrap; animation: scroll 38s linear infinite; width: max-content; }
.mt:hover { animation-play-state: paused; }
@keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.mp { display: inline-flex; align-items: center; gap: 9px; padding: 13px 26px; font-size: 0.83rem; font-weight: 700; white-space: nowrap; border-right: 1.5px solid #d4d4d4; color: #0a0a0a; }
.mp .dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.c-b .dot { background: var(--navy); }
.c-t .dot { background: var(--teal); }

/* SHARED SECTIONS */
.sec { padding: var(--section-pad); }
.sec-inner { max-width: var(--inner-max); margin: 0 auto; }
.lbl { font-size: 0.71rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--teal); margin-bottom: 10px; display: block; }
.lbl-dark { color: var(--navy); }
.ttl { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.1rem); font-weight: 900; line-height: 1.05; text-transform: uppercase; }
.ttl-dark { color: var(--dark); }
.sub { font-size: 0.98rem; color: rgba(255,255,255,.58); line-height: 1.78; max-width: 600px; }
.sub-dark { color: #5a5a5a; }

/* WHY AI MATTERS */
.why-ai-section { background: var(--dark2); }
.why-ai-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-top: 52px; background: rgba(255,255,255,.06); border-radius: var(--radius-card); overflow: hidden; border: 1.5px solid rgba(255,255,255,.06); }
.why-ai-card {
  background: #0e1520; padding: 36px 32px;
  position: relative; overflow: hidden;
  transition: background .2s;
}
.why-ai-card:hover { background: #121d2e; }
.why-ai-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--teal)); transform: scaleX(0); transform-origin: left; transition: transform .35s; }
.why-ai-card:hover::before { transform: scaleX(1); }
.why-ai-watermark { position: absolute; top: -10px; right: 16px; font-family: var(--font-display); font-size: 6.5rem; font-weight: 900; color: rgba(6,65,135,.12); line-height: 1; pointer-events: none; user-select: none; }
.why-ai-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; flex-shrink: 0; }
.why-ai-card h3 { font-family: var(--font-display); font-size: 1.35rem; font-weight: 900; text-transform: uppercase; color: #fff; letter-spacing: .04em; margin-bottom: 10px; line-height: 1.1; }
.why-ai-card p { font-size: 0.88rem; color: rgba(255,255,255,.55); line-height: 1.75; }

/* SERVICES DETAIL GRID */
.services-section { background: var(--dark); }
.services-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-top: 56px; background: rgba(255,255,255,.06); border-radius: var(--radius-card); overflow: hidden; border: 1.5px solid rgba(255,255,255,.06); }
.svc-detail-card {
  background: #0e1520; padding: 40px 36px;
  position: relative; overflow: hidden;
  transition: background .2s;
}
.svc-detail-card:hover { background: #121d2e; }
.svc-detail-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--teal)); transform: scaleX(0); transform-origin: left; transition: transform .35s; }
.svc-detail-card:hover::before { transform: scaleX(1); }
.svc-watermark { position: absolute; top: -10px; right: 16px; font-family: var(--font-display); font-size: 6.5rem; font-weight: 900; color: rgba(6,65,135,.12); line-height: 1; pointer-events: none; user-select: none; }
.svc-header { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
.svc-detail-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
.svc-detail-label { font-size: 0.68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--teal); margin-bottom: 3px; }
.svc-detail-name { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; text-transform: uppercase; color: #fff; letter-spacing: .03em; line-height: 1.05; }
.svc-detail-desc { font-size: 0.9rem; color: rgba(255,255,255,.55); line-height: 1.75; margin-bottom: 22px; }
.svc-checklist { list-style: none; display: flex; flex-direction: column; gap: 9px; }
.svc-checklist li { font-size: 0.875rem; color: rgba(255,255,255,.7); display: flex; align-items: flex-start; gap: 9px; line-height: 1.5; }
.chk { width: 18px; height: 18px; min-width: 18px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; margin-top: 1px; flex-shrink: 0; }
.chk-navy { background: var(--navy); }
.svc-key-fact { margin-top: 24px; padding: 14px 16px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 10px; border-left: 3px solid var(--teal); }
.svc-key-fact p { font-size: 0.83rem; color: rgba(255,255,255,.65); line-height: 1.6; }
.svc-key-fact strong { color: #fff; font-weight: 600; }

/* INBOX DELIVERABILITY HIGHLIGHT */
.deliverability-section { background: var(--dark2); }
.deliverability-inner { max-width: var(--inner-max); margin: 0 auto; }
.deliverability-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; margin-top: 52px; }
.deliverability-left h2 { font-family: var(--font-display); font-size: clamp(2.2rem, 4vw, 3.5rem); font-weight: 900; text-transform: uppercase; color: #fff; line-height: 1.02; margin-bottom: 22px; }
.deliverability-left h2 span { color: var(--teal); }
.deliverability-left p { font-size: 0.95rem; color: rgba(255,255,255,.58); line-height: 1.78; margin-bottom: 18px; }
.inbox-visual { background: rgba(255,255,255,.04); border: 1.5px solid rgba(255,255,255,.07); border-radius: 16px; padding: 24px; }
.inbox-row { display: flex; align-items: center; gap: 14px; padding: 12px 14px; border-radius: 10px; margin-bottom: 6px; }
.inbox-row.good { background: rgba(10,137,163,.1); border: 1px solid rgba(10,137,163,.25); }
.inbox-row.bad { background: rgba(234,67,53,.07); border: 1px solid rgba(234,67,53,.18); }
.inbox-row-icon { width: 36px; height: 36px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.inbox-row.good .inbox-row-icon { background: rgba(10,137,163,.25); }
.inbox-row.bad .inbox-row-icon { background: rgba(234,67,53,.2); }
.inbox-row-text { flex: 1; }
.inbox-row-label { font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,.4); letter-spacing: .08em; text-transform: uppercase; margin-bottom: 2px; }
.inbox-row-val { font-size: 0.9rem; font-weight: 600; }
.inbox-row.good .inbox-row-val { color: var(--teal); }
.inbox-row.bad .inbox-row-val { color: rgba(234,67,53,.8); }
.inbox-divider-label { font-size: 0.68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.25); text-align: center; padding: 8px 0; }

/* INDUSTRIES */
.industries-section { background: var(--dark); }
.industries-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; margin-top: 52px; background: rgba(255,255,255,.06); border-radius: var(--radius-card); overflow: hidden; border: 1.5px solid rgba(255,255,255,.06); }
.ind-card { background: #0e1520; padding: 28px 24px; display: flex; flex-direction: column; gap: 8px; transition: background .2s; position: relative; overflow: hidden; }
.ind-card:hover { background: #121d2e; }
.ind-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--teal)); transform: scaleX(0); transform-origin: left; transition: transform .35s; }
.ind-card:hover::before { transform: scaleX(1); }
.ind-icon { width: 46px; height: 46px; border-radius: 12px; background: rgba(6,65,135,.22); border: 1.5px solid rgba(6,65,135,.45); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-bottom: 4px; }
.ind-card h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 900; text-transform: uppercase; color: #fff; letter-spacing: .04em; line-height: 1.1; }
.ind-card p { font-size: 0.82rem; color: rgba(255,255,255,.48); line-height: 1.6; }

/* DECISION STATEMENTS */
.decision-section { background: var(--dark); padding: 0; overflow: hidden; }
.decision-label { text-align: center; padding: 72px 5% 0; max-width: var(--inner-max); margin: 0 auto; }
.decision-statements { display: flex; flex-direction: column; gap: 0; margin-top: 48px; }
.decision-stmt { display: flex; align-items: center; min-height: 130px; padding: 32px 5%; position: relative; overflow: hidden; }
.decision-stmt-1 { background: var(--navy); }
.decision-stmt-2 { background: var(--teal); }
.decision-stmt-3 { background: var(--navy); }
.decision-num { font-family: var(--font-display); font-size: clamp(5rem, 11vw, 9rem); font-weight: 900; line-height: 1; color: rgba(255,255,255,.08); position: absolute; right: 5%; top: 50%; transform: translateY(-50%); letter-spacing: -.04em; user-select: none; pointer-events: none; }
.decision-text-wrap { max-width: var(--inner-max); width: 100%; margin: 0 auto; display: flex; align-items: center; gap: 28px; }
.decision-stmt-icon { width: 52px; height: 52px; flex-shrink: 0; border-radius: 14px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.12); border: 1.5px solid rgba(255,255,255,.2); }
.decision-stmt-2 .decision-stmt-icon { background: rgba(6,65,135,.25); border: 1.5px solid rgba(6,65,135,.45); }
.decision-text { font-family: var(--font-display); font-size: clamp(1.8rem, 3.5vw, 3.2rem); font-weight: 900; text-transform: uppercase; letter-spacing: -.01em; line-height: 1.05; color: #fff; }
.decision-text em { font-style: normal; color: var(--teal); }
.decision-stmt-2 .decision-text em { color: var(--navy); }
.decision-payoff { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 28px; padding: 72px 5% 80px; background: var(--dark); position: relative; }
.decision-payoff::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--teal), var(--navy)); }
.decision-payoff-eyebrow { font-size: 0.72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--teal); }
.decision-payoff-text { font-family: var(--font-display); font-size: clamp(2.6rem, 5.5vw, 5rem); font-weight: 900; text-transform: uppercase; letter-spacing: -.02em; line-height: 0.97; color: #fff; }
.decision-payoff-text span { color: var(--teal); }

/* HOW IT WORKS STEPS */
.how-section { background: var(--dark2); }
.steps-row { display: grid; grid-template-columns: repeat(5,1fr); gap: 0; position: relative; margin-top: 56px; }
.steps-row::before { content: ''; position: absolute; top: 27px; left: calc(10% + 28px); right: calc(10% + 28px); height: 2px; background: linear-gradient(90deg, var(--navy), var(--teal), var(--navy)); z-index: 0; }
.step-item { text-align: center; padding: 0 12px; position: relative; z-index: 1; }
.step-num { width: 56px; height: 56px; border-radius: 50%; background: var(--navy); color: #fff; font-family: var(--font-display); font-weight: 900; font-size: 1.25rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 0 0 6px var(--dark2), 0 0 0 8px var(--navy); position: relative; z-index: 2; }
.step-item:nth-child(even) .step-num { background: var(--teal); box-shadow: 0 0 0 6px var(--dark2), 0 0 0 8px var(--teal); }
.step-item h3 { font-family: var(--font-display); font-size: 1rem; font-weight: 900; text-transform: uppercase; color: #fff; margin-bottom: 8px; letter-spacing: .04em; }
.step-item p { font-size: 0.8rem; color: rgba(255,255,255,.48); line-height: 1.6; }

/* PAIN POINTS */
.pain-section { background: var(--dark); }
.pain-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 2px; margin-top: 48px; background: rgba(255,255,255,.06); border-radius: 24px; overflow: hidden; border: 1.5px solid rgba(255,255,255,.06); }
.pain-card { background: #0e1520; padding: 0; transition: background .25s; position: relative; overflow: hidden; }
.pain-card:hover { background: #121d2e; }
.pain-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--teal)); transform: scaleX(0); transform-origin: left; transition: transform .35s; }
.pain-card:hover::before { transform: scaleX(1); }
.pain-num-watermark { position: absolute; top: -10px; right: 16px; font-family: var(--font-display); font-size: 7rem; font-weight: 900; color: rgba(6,65,135,.12); line-height: 1; pointer-events: none; user-select: none; }
.pain-inner { padding: 36px 32px 30px; position: relative; }
