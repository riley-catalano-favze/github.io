        <div class="why-ai-watermark">04</div>
        <div class="why-ai-icon icon-n">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 10h10M4 14h12M4 18h8" stroke="#064187" stroke-width="1.7" stroke-linecap="round"/></svg>
